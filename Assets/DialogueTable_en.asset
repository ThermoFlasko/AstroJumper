  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: DialogueTable_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 77cdd053a5fb34f85899ea6309a2de7c, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 41799376896
    m_Localized: General Hayes
    m_Metadata:
      m_Items: []
  - m_Id: 45758799872
    m_Localized: Vanguard!
    m_Metadata:
      m_Items: []
  - m_Id: 49550450688
    m_Localized: We're under attack by an unidentified force! We need your help!
    m_Metadata:
      m_Items: []
  - m_Id: 52512588554240
    m_Localized: ???
    m_Metadata:
      m_Items: []
  - m_Id: 1262339633438720
    m_Localized: Hope my Astrojumper still works. I'll need all the help I can get.
    m_Metadata:
      m_Items: []
  - m_Id: 1262342598811648
    m_Localized: "Hmmm. Looks like they dropped some scrap. This might be useful\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1262344872124416
    m_Localized: "Vanguard. I don\u2019t know who or what these aliens are. "
    m_Metadata:
      m_Items: []
  - m_Id: 1267418142859264
    m_Localized: But we are gonna send 'em back to wherever the hell they came from.
    m_Metadata:
      m_Items: []
  - m_Id: 1267422433632256
    m_Localized: We're gonna disable that mothership of theirs. We need your help.
    m_Metadata:
      m_Items: []
  - m_Id: 1269217792876544
    m_Localized: Just sent you the location for their fleet. We're taking these lizards
      down.
    m_Metadata:
      m_Items: []
  - m_Id: 1269219185385472
    m_Localized: Our scans indicate the main ship is protected by shield pylons and
      a fleet of skirmishers.
    m_Metadata:
      m_Items: []
  - m_Id: 1269220389150720
    m_Localized: We need to take down those shields. Then, slip through their defenses
      and disable it from the inside.
    m_Metadata:
      m_Items: []
  - m_Id: 1269221685190656
    m_Localized: Before we begin the assault, it looks like you have picked up some
      scrap. Let's upgrade our weapons. We'll need the firepower boost.
    m_Metadata:
      m_Items: []
  - m_Id: 1269222977036288
    m_Localized: Alright. Our fleets have mobilized, and are waiting for your signal.
    m_Metadata:
      m_Items: []
  - m_Id: 29923535844532224
    m_Localized: Press A or D to move
    m_Metadata:
      m_Items: []
  - m_Id: 29923535869698048
    m_Localized: Press W or SPACE to jump
    m_Metadata:
      m_Items: []
  - m_Id: 29923535869698049
    m_Localized: Press W or SPACE twice to double jump
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892352
    m_Localized: Press SHIFT to sprint
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892353
    m_Localized: Press LMB to shoot
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892354
    m_Localized: Press RMB to melee
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892355
    m_Localized: I need to get to my Astrojumper.
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892356
    m_Localized: Press W to accelerate speed
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892357
    m_Localized: Press A or D to turn
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892358
    m_Localized: Press S to slow down
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892359
    m_Localized: Press SHIFT to boost
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892360
    m_Localized: SCROLL to control zoom
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892361
    m_Localized: Press LMB to fire blasters
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892362
    m_Localized: Press RMB to use alternative firing mode
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892363
    m_Localized: The ship is protected by a shield. I need to target the pylons to
      disable it.
    m_Metadata:
      m_Items: []
  - m_Id: 31596842549501952
    m_Localized: Press S to drop through platforms
    m_Metadata:
      m_Items: []
  - m_Id: 31596844076228608
    m_Localized: Press and Hold W or SPACE to jump higher
    m_Metadata:
      m_Items: []
  - m_Id: 31596845380657152
    m_Localized: You can disable tooltips in the options menu
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
