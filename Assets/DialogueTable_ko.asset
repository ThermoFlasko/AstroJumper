  m_TableData:
  - m_Id: 41799376896
    m_Localized: "\uD5E4\uC774\uC988 \uC7A5\uAD70"
    m_Metadata:
      m_Items: []
  - m_Id: 45758799872
    m_Localized: "\uBC45\uAC00\uB4DC!"
    m_Metadata:
      m_Items: []
  - m_Id: 49550450688
    m_Localized: "\uBBF8\uD655\uC778 \uC138\uB825\uC758 \uACF5\uACA9\uC744 \uBC1B\uACE0
      \uC788\uC2B5\uB2C8\uB2E4! \uB2F9\uC2E0\uC758 \uB3C4\uC6C0\uC774 \uD544\uC694\uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 52512588554240
    m_Localized: ???
    m_Metadata:
      m_Items: []
  - m_Id: 1262339633438720
    m_Localized: "\uB0B4 \uC544\uC2A4\uD2B8\uB85C\uC810\uD37C \uC544\uC9C1 \uC791\uB3D9\uD558\uAE38
      \uBC14\uB798\uC694. \uD560 \uC218 \uC788\uB294 \uBAA8\uB4E0 \uB3C4\uC6C0\uC774
      \uD544\uC694\uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1262342598811648
    m_Localized: "\uD760. \uADF8\uB4E4\uC774 \uC2A4\uD06C\uB7A9\uC744 \uB5A8\uC5B4\uB728\uB9B0
      \uAC83 \uAC19\uC544\uC694. \uC774\uAC8C \uC720\uC6A9\uD560\uC9C0\uB3C4 \uBAB0\uB77C\uC694\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1262344872124416
    m_Localized: "\uBC45\uAC00\uB4DC. \uC774 \uC678\uACC4\uC778\uB4E4\uC774 \uB204\uAD6C\uC778\uC9C0,
      \uBB34\uC5C7\uC778\uC9C0 \uBAA8\uB974\uACA0\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1267418142859264
    m_Localized: "\uD558\uC9C0\uB9CC \uC6B0\uB9AC\uB294 \uADF8\uB188\uB4E4\uC744
      \uADF8\uB4E4\uC774 \uC9C0\uC625\uC5D0\uC11C \uC628 \uACF3\uC73C\uB85C \uB2E4\uC2DC
      \uBCF4\uB0BC \uAC70\uC608\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1267422433632256
    m_Localized: "\uC6B0\uB9AC\uB294 \uADF8\uB4E4\uC758 \uBAA8\uC120\uC744 \uBB34\uB825\uD654\uC2DC\uD0AC
      \uAC70\uC608\uC694. \uB2F9\uC2E0\uC758 \uB3C4\uC6C0\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1269217792876544
    m_Localized: "\uBC29\uAE08 \uADF8\uB4E4\uC758 \uD568\uB300 \uC704\uCE58\uB97C
      \uBCF4\uB0C8\uC5B4\uC694. \uC774 \uB3C4\uB9C8\uBC40\uB4E4\uC744 \uB05D\uC7A5\uB0B4\uBC84\uB9AC\uC790\uACE0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1269219185385472
    m_Localized: "\uC2A4\uCE94 \uACB0\uACFC \uC8FC\uB825\uD568\uC740 \uBC29\uC5B4\uB9C9
      \uBC1C\uC0DD\uAE30\uC640 \uC815\uCC30\uD568\uB300\uC758 \uBCF4\uD638\uB97C
      \uBC1B\uACE0 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1269220389150720
    m_Localized: "\uADF8 \uBC29\uC5B4\uB9C9\uBD80\uD130 \uBB34\uB108\uB728\uB824\uC57C
      \uD574\uC694. \uADF8\uB7F0 \uB2E4\uC74C, \uBC29\uC5B4\uC120\uC744 \uB6AB\uACE0
      \uB0B4\uBD80\uC5D0\uC11C \uBB34\uB825\uD654\uC2DC\uD0A4\uB294 \uAC70\uC608\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1269221685190656
    m_Localized: "\uACF5\uACA9\uC744 \uC2DC\uC791\uD558\uAE30 \uC804\uC5D0, \uB2F9\uC2E0\uC774
      \uC2A4\uD06C\uB7A9\uC744 \uC880 \uC8FC\uC6E0\uB098 \uBCF4\uB124\uC694. \uBB34\uAE30\uB97C
      \uC5C5\uADF8\uB808\uC774\uB4DC\uD569\uC2DC\uB2E4. \uD654\uB825 \uC9C0\uC6D0\uC774
      \uD544\uC694\uD560 \uAC70\uC608\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 1269222977036288
    m_Localized: "\uC88B\uC544\uC694. \uC6B0\uB9AC \uD568\uB300\uAC00 \uCD9C\uB3D9\uD588\uC5B4\uC694.
      \uB2F9\uC2E0\uC758 \uC2E0\uD638\uB97C \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 29923535844532224
    m_Localized: "{leftKey} \uB610\uB294 {rightKey}\uB85C \uC774\uB3D9"
