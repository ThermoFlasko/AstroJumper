  - m_Id: 29923535873892359
    m_Localized: "{boostKey}\uB85C \uBD80\uC2A4\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892360
    m_Localized: "\uC2A4\uD06C\uB864\uB85C \uC90C \uC870\uC808"
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892361
    m_Localized: "{fireKey}\uB85C \uBE14\uB798\uC2A4\uD130 \uBC1C\uC0AC"
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892362
    m_Localized: "{altFireKey}\uB85C \uB300\uCCB4 \uBC1C\uC0AC \uBAA8\uB4DC \uC0AC\uC6A9"
    m_Metadata:
      m_Items: []
  - m_Id: 29923535873892363
    m_Localized: "\uD568\uC120\uC774 \uBC29\uC5B4\uB9C9\uC73C\uB85C \uBCF4\uD638\uBC1B\uACE0
      \uC788\uC5B4\uC694. \uD30C\uC77C\uB860\uC744 \uBAA9\uD45C\uB85C \uC0BC\uC544
      \uBB34\uB825\uD654\uC2DC\uCF1C\uC57C \uD574\uC694."
